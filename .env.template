# SparkOCR-VLM — copy to .env and fill in real values
# .env is git-ignored; never commit real keys

# --- VLM Backends ---
OPENROUTER_API_KEY=           # default backend; get free key at openrouter.ai
TOGETHER_API_KEY=             # optional; together.ai
GEMINI_API_KEY=               # optional; aistudio.google.com
MODAL_TOKEN_ID=               # optional; modal.com
MODAL_TOKEN_SECRET=           # optional; modal.com

# --- Databricks Free Edition ---
DATABRICKS_HOST=              # e.g. https://adb-XXXX.azuredatabricks.net
DATABRICKS_TOKEN=             # personal access token

# --- Local MinIO (docker-compose up) ---
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- Default backend + model ---
SPARKOCR_DEFAULT_BACKEND=openrouter
SPARKOCR_DEFAULT_MODEL=google/gemma-4-31b-it:free   # free tier; no credits needed

# --- Behavior flags ---
SPARKOCR_LOG_COSTS=0          # set 1 to append cost log to runtime/COSTS.md
SPARKOCR_PRIVATE_RUNTIME=0    # set 1 to exclude runtime/ from git
